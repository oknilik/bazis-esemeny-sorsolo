generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Participant {
  id        String    @id @default(cuid())
  name      String
  email     String?
  code      String    @default("")
  createdAt DateTime  @default(now())
  isWinner  Boolean   @default(false)
  wonAt     DateTime?
  drawOrder Int?
}
